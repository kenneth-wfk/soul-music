{
  "name": "soulfest-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:soul-music-main": "turbo build --filter=soul-music-main",
    "build:2020-kham-info": "turbo build --filter=2020-kham-info",
    "build:2026-kham-info": "turbo build --filter=2026-kham-info",
    "dev": "turbo dev",
    "dev:soul-music-main": "turbo dev --filter=soul-music-main",
    "dev:2020-kham-info": "turbo dev --filter=2020-kham-info",
    "dev:2026-kham-info": "turbo dev --filter=2026-kham-info",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.8.0"
}
